 13  '.feedback-positive { color: var(--ut-feedback-positive-text-color, var(--ut-palette-success)); }',
 14  '.feedback-neutral { color: var(--ut-feedback-neutral-text-color, var(--ut-palette-warning)); }',
 15  '.feedback-negative { color: var(--ut-feedback-negative-text-color, var(--ut-palette-danger)); }'))
