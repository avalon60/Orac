 74  'with nw as (',
 75  '	  -- APEX_ACTIVITY_LOG uses dates; convert system time to local time zone.',
 76  '	  select from_tz( cast( sysdate as timestamp ), to_char( systimestamp, ''TZR'' ) ) at local as tm from dual',
 77  '),',
 78  'window as (',
 79  '	  select',
 80  '	       trunc(nw.tm - ((level-1)/24),''HH'') start_tm,',
 81  '	       trunc(nw.tm - ((level-2)/24),''HH'') end_tm,',
 82  '	       trunc(sysdate-((level-1)/24),''HH'') log_start_tm,',
 83  '	       trunc(sysdate-((level-2)/24),''HH'') log_end_tm',
 84  '	  from nw',
 85  '	  connect by level <= round( 24 * ( 1/24/60/60 * nvl(:P10030_TIMEFRAME,1) ) )',
 86  ')',
 87  'select w.start_tm log_time,',
 88  '	     ( select count(*)',
 89  '		 from apex_activity_log l',
 90  '		where l.flow_id = :app_id',
 91  '		  and l.time_stamp between w.log_start_tm and w.log_end_tm ) as value',
 92  'from window w',
 93  'order by 1'))
 94  ,p_max_row_count=>350
 95  ,p_ajax_items_to_submit=>'P10030_TIMEFRAME'
