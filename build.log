 30    function get_setting(p_key in varchar2) return varchar2
 31    is
 32  	 l_val orac.auth_settings.setting_value%type;
 33    begin
 34  	 select setting_value
 35  	   into l_val
 36  	   from orac.auth_settings
 37  	  where setting_key = p_key;
 38  
 39  	 return l_val;
 40    exception
 41  	 when no_data_found then
 42  	   return null;
 43    end;
 44  
 45    function fresh_timestamp(p_iso_utc in varchar2, p_skew_seconds in pls_integer default 120) return boolean
 46    is
 47  	 l_ts_utc   timestamp with time zone;
 48  	 l_now_utc  timestamp with time zone := systimestamp at time zone 'UTC';
 49    begin
 50  	 l_ts_utc := to_timestamp_tz(p_iso_utc, 'yyyy-mm-dd"T"hh24:mi:ss"Z"');
 51  	 if abs(extract(second from (l_now_utc - l_ts_utc))
 52  	      + 60*extract(minute from (l_now_utc - l_ts_utc))
 53  	      + 3600*extract(hour from (l_now_utc - l_ts_utc))
 54  	      + 86400*extract(day from (l_now_utc - l_ts_utc))) <= p_skew_seconds
 55  	 then
 56  	   return true;
 57  	 end if;
 58  	 return false;
 59    exception
 60  	 when others then
 61  	   return false;
 62    end;
 63  
 64    function nonce_unused(p_nonce in varchar2, p_ttl_seconds in pls_integer default 600) return boolean
 65    is
 66  	 l_cnt integer;
 67    begin
 68  	 select count(*)
 69  	   into l_cnt
 70  	   from orac.auth_nonces
 71  	  where nonce = p_nonce
 72  	    and created_on > systimestamp - numtodsinterval(p_ttl_seconds, 'second');
 73  
 74  	 return l_cnt = 0;
 75    end;
 76  
 77    procedure mark_nonce_used(p_nonce in varchar2)
 78    is
 79    begin
 80  	 insert into orac.auth_nonces (nonce) values (p_nonce);
 81  	 commit;
 82    exception
 83  	 when dup_val_on_index then null;
 84    end;
 85  
 86    function resolve_user(p_os_user in varchar2) return varchar2
 87    is
 88  	 l_user_id orac.user_synonyms.user_id%type;
 89    begin
 90  	 select user_id
 91  	   into l_user_id
 92  	   from orac.user_synonyms
 93  	  where alias_type = 'os'
 94  	    and alias_value = p_os_user
 95  	    and is_active = 1;
 96  
 97  	 return l_user_id;
 98    exception
 99  	 when no_data_found then
100  	   return null;
101    end;
102  
103    function device_allowed(p_device_id in varchar2, p_user_id in varchar2) return boolean
104    is
105  	 l_dummy number;
106    begin
107  	 select 1
108  	   into l_dummy
109  	   from orac.devices
110  	  where device_id = p_device_id
111  	    and user_id   = p_user_id
112  	    and is_active = 1;
113  
114  	 return true;
115    exception
116  	 when no_data_found then
117  	   return false;
118    end;
119  
120    procedure set_session_identity(p_user_id in varchar2, p_host in varchar2, p_device in varchar2)
121    is
122    begin
123  	 dbms_session.set_identifier(p_user_id);
124  	 dbms_application_info.set_client_info(substr(nvl(p_host,'?')||'|'||nvl(p_device,'?'), 1, 64));
125    end;
126  
127    procedure slave_precheck(p_require_sig in boolean default true)
128    is
129  	 l_os_user   varchar2(256) := header('X-Zen-User');
130  	 l_devid     varchar2(256) := nvl(header('X-Zen-Devid'), header('X-Zen-Mac'));
131  	 l_host      varchar2(256) := header('X-Zen-Host');
132  	 l_user_id   varchar2(64);
133    begin
134  	 l_user_id := resolve_user(l_os_user);
135  
136  	 if l_user_id is null then
137  	   owa_util.status_line(403, 'forbidden');
138  	   htp.p('unknown user');
139  	   return;
140  	 end if;
141  
142  	 if not device_allowed(l_devid, l_user_id) then
143  	   owa_util.status_line(403, 'forbidden');
144  	   htp.p('device not allowed');
145  	   return;
146  	 end if;
147  
148  	 set_session_identity(l_user_id, l_host, l_devid);
149    end;
150  end orac_utils;
151  /

