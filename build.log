238  'for l_feedback in (',
239  '	 select page_id,',
240  '		page_name,',
241  '		case feedback_rating',
242  '		      when 1 then ''<span class="fa fa-frown-o feedback-negative" aria-hidden="true" title="Negative"></span>'' ',
243  '		      when 2 then ''<span class="fa fa-emoji-neutral feedback-neutral" aria-hidden="true" title="Neutral"></span>''  ',
244  '		      when 3 then ''<span class="fa fa-smile-o feedback-positive" aria-hidden="true" title="Positive"></span>'' ',
245  '		      end rating_icon,',
246  '		lower(created_by) || '' - '' || apex_util.get_since(created_on) filed,',
247  '		feedback,',
248  '		public_response,',
249  '		feedback_status,',
250  '		http_user_agent',
251  '	   from apex_team_feedback',
252  '	  where feedback_id = :P10054_ID )',
253  'loop',
254  '	 :P10054_PAGE_ID	 := l_feedback.page_id||''. ''||l_feedback.page_name;',
255  '	 :P10054_FILED		 := l_feedback.filed;',
256  '	 :P10054_RATING_ICON	 := l_feedback.rating_icon;',
257  '	 :P10054_FEEDBACK	 := l_feedback.feedback;',
258  '	 :P10054_RESPONSE	 := l_feedback.public_response;',
259  '	 :P10054_FEEDBACK_STATUS := l_feedback.feedback_status;',
260  '	 :P10054_USER_AGENT	 := l_feedback.http_user_agent;',
261  'end loop;'))
