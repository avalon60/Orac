SQL> SQL> create or replace package orac_utils authid definer
  2  as
  3    -----------------------------------------------------------------------------
  4    --  orac_utils
  5    --
  6    --  Utility package for Zen → ORDS prechecks. Provides helpers to:
  7    --	• read HTTP headers in an ORDS context
  8    --	• resolve OS usernames → canonical user_ids
  9    --	• validate devices against allow-list
 10    --	• optional HMAC/timestamp/nonce verification for spoof/replay protection
 11    --	• set DB session identity for auditing/row-level security
 12    --
 13    --  Typical usage in an ORDS handler:
 14    --	begin
 15    --	  orac_utils.slave_precheck; -- raises 403 if checks fail
 16    --	  -- continue with business logic
 17    --	end;
 18    -----------------------------------------------------------------------------
 19  
 20    -----------------------------------------------------------------------------
 21    -- Return the value of an HTTP header from OWA/ORDS environment.
 22    -- Example: header('X-Zen-User') → 'clive'
 23    -----------------------------------------------------------------------------
 24    function header(p_name in varchar2) return varchar2;
 25  
 26    -----------------------------------------------------------------------------
 27    -- Base64url decode (helper for HMAC).
 28    -----------------------------------------------------------------------------
 29    function b64url_to_raw(p_b64url in varchar2) return raw;
 30  
 31    -----------------------------------------------------------------------------
 32    -- Compute HMAC-SHA256 of a message using the provided raw secret.
 33    -- Example: hmac_sha256(secret_raw, 'clive|AA:BB|2025-08-22T...|nonce')
 34    -----------------------------------------------------------------------------
 35    function hmac_sha256(p_secret_raw in raw, p_message in varchar2) return raw;
 36  
 37    -----------------------------------------------------------------------------
 38    -- Lookup a configuration setting in orac.auth_settings.
 39    -- Used to retrieve shared HMAC secret or other auth parameters.
 40    -----------------------------------------------------------------------------
 41    function get_setting(p_key in varchar2) return varchar2;
 42  
 43    -----------------------------------------------------------------------------
 44    -- Check if a supplied ISO8601 UTC timestamp is “fresh” within
 45    -- a skew allowance (default ±120 seconds).
 46    -- Returns true if valid, false otherwise.
 47    -----------------------------------------------------------------------------
 48    function fresh_timestamp(
 49  	 p_iso_utc	in varchar2,
 50  	 p_skew_seconds in pls_integer default 120
 51    ) return boolean;
 52  
 53    -----------------------------------------------------------------------------
 54    -- Verify that a nonce value has not been used recently.
 55    -- Returns true if unused within ttl_seconds (default 600).
 56    -- Call mark_nonce_used afterwards to persist the nonce.
 57    -----------------------------------------------------------------------------
 58    function nonce_unused(
 59  	 p_nonce       in varchar2,
 60  	 p_ttl_seconds in pls_integer default 600
 61    ) return boolean;
 62  
 63    -----------------------------------------------------------------------------
 64    -- Record a nonce as “used” in orac.auth_nonces.
 65    -- Used to prevent replay attacks.
 66    -----------------------------------------------------------------------------
 67    procedure mark_nonce_used(p_nonce in varchar2);
 68  
 69    -----------------------------------------------------------------------------
 70    -- Resolve an OS username (alias_type = 'os') into a canonical user_id.
 71    -- Returns null if not found or inactive.
 72    -----------------------------------------------------------------------------
 73    function resolve_user(p_os_user in varchar2) return varchar2;
 74  
 75    -----------------------------------------------------------------------------
 76    -- Check whether a device is allowed for a given user_id.
 77    -- Returns true if a matching row exists in orac.devices.
 78    -----------------------------------------------------------------------------
 79    function device_allowed(
 80  	 p_device_id in varchar2,
 81  	 p_user_id   in varchar2
 82    ) return boolean;
 83  
 84    -----------------------------------------------------------------------------
 85    -- Tag the current DB session with user_id + host/device info.
 86    -- Sets DBMS_SESSION.CLIENT_IDENTIFIER and DBMS_APPLICATION_INFO.CLIENT_INFO.
 87    -----------------------------------------------------------------------------
 88    procedure set_session_identity(
 89  	 p_user_id in varchar2,
 90  	 p_host    in varchar2,
 91  	 p_device  in varchar2
 92    );
 93  
 94    -----------------------------------------------------------------------------
 95    -- Main entrypoint for Zen request validation.
 96    --
 97    -- Steps performed:
 98    --   1. Read X-Zen-User, X-Zen-DevID/MAC, X-Zen-Host headers.
 99    --   2. Resolve OS user → canonical user_id via orac.user_synonyms.
100    --   3. Check device allow-list in orac.devices.
101    --   4. If p_require_sig=true, optional HMAC/timestamp/nonce verification
102    --	  can be added (future extension).
103    --   5. Tag session identity.
104    --
105    -- On failure: sets HTTP 403 Forbidden and stops execution.
106    -----------------------------------------------------------------------------
107    procedure slave_precheck(p_require_sig in boolean default true);
108  
109  end orac_utils;
110  /

