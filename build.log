SQL> -- iot: user_preferences_v_iud — normalize display value → JSON scalar; route DML to base table
SQL> create or replace trigger orac.user_preferences_v_iud
  2  instead of insert or update or delete on orac.user_preferences_v
  3  for each row
  4  declare
  5    l_json_txt  clob;	-- JSON text to pass to json(...)
  6    l_bool_txt  varchar2(5);
  7    l_new_id    number;
  8  begin
  9    if inserting or updating then
 10  	 if :new.value_type not in ('string','number','boolean') then
 11  	   raise_application_error(-20002, 'Unknown value_type: '||:new.value_type);
 12  	 end if;
 13  
 14  	 if :new.value_type = 'string' then
 15  	   l_json_txt := '"' || replace(nvl(:new.value_display,''), '"', '\"') || '"';
 16  	 elsif :new.value_type = 'number' then
 17  	   begin
 18  	     declare d number; begin d := to_number(trim(:new.value_display)); end;
 19  	   exception when others then
 20  	     raise_application_error(-20003, 'Invalid number: '||:new.value_display);
 21  	   end;
 22  	   l_json_txt := trim(:new.value_display);
 23  	 else
 24  	   l_bool_txt :=
 25  	     case lower(nvl(:new.value_display,'false'))
 26  	       when 'true' then 'true'
 27  	       when '1'    then 'true'
 28  	       when 'yes'  then 'true'
 29  	       when 'y'    then 'true'
 30  	       else 'false'
 31  	     end;
 32  	   l_json_txt := l_bool_txt;
 33  	 end if;
 34    end if;
 35  
 36    if inserting then
 37  	 insert into orac.user_preferences (user_id, pref_key, value_type, pref_value)
 38  	 values (:new.user_id, :new.pref_key, :new.value_type, json(l_json_txt))
 39  	 returning pref_id into l_new_id;
 40  	 -- NOTE: cannot assign :new.pref_id in INSTEAD OF trigger; allow APEX to re-query
 41  
 42    elsif updating then
 43  	 update orac.user_preferences
 44  	    set user_id    = :new.user_id,
 45  		pref_key   = :new.pref_key,
 46  		value_type = :new.value_type,
 47  		pref_value = json(l_json_txt)
 48  	  where pref_id = :old.pref_id;
 49  
 50    elsif deleting then
 51  	 delete from orac.user_preferences
 52  	  where pref_id = :old.pref_id;
 53    end if;
 54  end;
 55  /

Trigger created.

