SQL> SQL> create or replace package body orac.orac_prefs_seed as
  2  -- ===================================================================
  3  -- author	    : clive bostock
  4  -- date	    : 2025-08-31
  5  -- description : default preference seeding into orac.user_preferences.
  6  -- 	      stores valid json literals as text; oracle implicitly
  7  -- 	      converts to json data type on insert/update.
  8  -- 	      now also seeds/updates value_type ('string','number','boolean').
  9  -- ===================================================================
 10  
 11    ------------------------------------------------------------------------------
 12    -- defaults_q
 13    -- returns one varchar per row in the form:
 14    --   key <TAB> value_type <TAB> json_literal
 15    -- examples of json_literal:
 16    --   '"DD-MON-YYYY HH24:MI"'	-- json string
 17    --   50			     -- json number
 18    --   true / false	     -- json boolean
 19    ------------------------------------------------------------------------------
 20    function defaults_q return sys.odcivarchar2list pipelined is
 21  	 sep constant varchar2(1) := chr(9);
 22    begin
 23  	 pipe row('date_format' 	 || sep || 'string'  || sep || '"DD-MON-YYYY HH24:MI"');
 24  	 pipe row('timezone'		 || sep || 'string'  || sep || '"Europe/London"');
 25  	 pipe row('theme_style' 	 || sep || 'string'  || sep || '"Vita"');
 26  	 pipe row('landing_page_id'	 || sep || 'number'  || sep || '0');
 27  	 pipe row('rows_per_report'	 || sep || 'number'  || sep || '50');
 28  
 29  	 pipe row('email_opt_in'	 || sep || 'boolean' || sep || 'true');
 30  	 pipe row('push_opt_in' 	 || sep || 'boolean' || sep || 'false');
 31  
 32  	 pipe row('tts_voice'		 || sep || 'string'  || sep || '"en-GB-female-1"');
 33  	 pipe row('tts_rate'		 || sep || 'number'  || sep || '0.95');
 34  	 pipe row('tts_pitch'		 || sep || 'number'  || sep || '0.0');
 35  
 36  	 -- use 0 instead of json null to satisfy USER_PREF_CK1
 37  	 pipe row('default_llm_id'	 || sep || 'number'  || sep || '0');
 38  
 39  	 pipe row('temperature' 	 || sep || 'number'  || sep || '0.2');
 40  	 pipe row('max_tokens'		 || sep || 'number'  || sep || '512');
 41  	 pipe row('strip_reasoning_tags' || sep || 'boolean' || sep || 'true');
 42  	 pipe row('show_reasoning'	 || sep || 'boolean' || sep || 'false');
 43  	 pipe row('force_concise'	 || sep || 'boolean' || sep || 'true');
 44  
 45  	 pipe row('enable_feedback'	 || sep || 'boolean' || sep || 'true');
 46  	 pipe row('enable_advanced_mode' || sep || 'boolean' || sep || 'false');
 47  	 return;
 48    end defaults_q;
 49  
 50    ------------------------------------------------------------------------------
 51    -- seed_user: insert any missing prefs; optionally overwrite existing values.
 52    -- p_overwrite=false → only inserts missing keys
 53    -- p_overwrite=true  → inserts missing + updates existing with new defaults
 54    ------------------------------------------------------------------------------
 55    procedure seed_user(p_user_id in number, p_overwrite in boolean default false) is
 56    begin
 57  	 -- ensure the user exists
 58  	 declare
 59  	   l_dummy number;
 60  	 begin
 61  	   select 1 into l_dummy from orac.users where user_id = p_user_id;
 62  	 exception
 63  	   when no_data_found then
 64  	     raise_application_error(-20001, 'User '||p_user_id||' does not exist in ORAC.USERS');
 65  	 end;
 66  
 67  	 -- parse triples: key, value_type, json_lit
 68  	 -- pattern: ^([^\t]+)\t([^\t]+)\t(.*)$  → subexpr 1,2,3
 69  	 merge into orac.user_preferences p
 70  	 using (
 71  	   select
 72  	     regexp_substr(t.column_value,
 73  			   '^([^' || chr(9) || ']+)' || chr(9) ||
 74  			   '([^' || chr(9) || ']+)' || chr(9) ||
 75  			   '(.*)$', 1, 1, null, 1) as pref_key,
 76  	     regexp_substr(t.column_value,
 77  			   '^([^' || chr(9) || ']+)' || chr(9) ||
 78  			   '([^' || chr(9) || ']+)' || chr(9) ||
 79  			   '(.*)$', 1, 1, null, 2) as value_type,
 80  	     regexp_substr(t.column_value,
 81  			   '^([^' || chr(9) || ']+)' || chr(9) ||
 82  			   '([^' || chr(9) || ']+)' || chr(9) ||
 83  			   '(.*)$', 1, 1, null, 3) as json_lit
 84  	   from table(defaults_q) t
 85  	 ) d
 86  	 on (p.user_id = p_user_id and p.pref_key = d.pref_key)
 87  	 when not matched then
 88  	   insert (user_id, pref_key, value_type, pref_value)
 89  	   values (p_user_id, d.pref_key, d.value_type, d.json_lit);
 90  
 91  	 if p_overwrite then
 92  	   merge into orac.user_preferences p
 93  	   using (
 94  	     select
 95  	       regexp_substr(t.column_value,
 96  			     '^([^' || chr(9) || ']+)' || chr(9) ||
 97  			     '([^' || chr(9) || ']+)' || chr(9) ||
 98  			     '(.*)$', 1, 1, null, 1) as pref_key,
 99  	       regexp_substr(t.column_value,
100  			     '^([^' || chr(9) || ']+)' || chr(9) ||
101  			     '([^' || chr(9) || ']+)' || chr(9) ||
102  			     '(.*)$', 1, 1, null, 2) as value_type,
103  	       regexp_substr(t.column_value,
104  			     '^([^' || chr(9) || ']+)' || chr(9) ||
105  			     '([^' || chr(9) || ']+)' || chr(9) ||
106  			     '(.*)$', 1, 1, null, 3) as json_lit
107  	     from table(defaults_q) t
108  	   ) d
109  	   on (p.user_id = p_user_id and p.pref_key = d.pref_key)
110  	   when matched then
111  	     update set p.value_type = d.value_type,
112  			p.pref_value = d.json_lit;
113  	 end if;
114  
115  	 commit;
116    end seed_user;
117  
118    ------------------------------------------------------------------------------
119    -- seed_all: apply seed_user to all active users
120    ------------------------------------------------------------------------------
121    procedure seed_all(p_overwrite in boolean default false) is
122    begin
123  	 for r in (select user_id from orac.users where is_active = 'Y') loop
124  	   seed_user(p_user_id => r.user_id, p_overwrite => p_overwrite);
125  	 end loop;
126    end seed_all;
127  
128  end orac_prefs_seed;
129  /

Package body created.

