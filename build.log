194  wwv_flow_imp_page.create_page_process(
195   p_id=>wwv_flow_imp.id(11487738226769175)
196  ,p_process_sequence=>20
197  ,p_process_point=>'AFTER_SUBMIT'
198  ,p_process_type=>'NATIVE_PLSQL'
199  ,p_process_name=>'Save End User Style Preference'
200  ,p_process_sql_clob=>wwv_flow_string.join(wwv_flow_t_varchar2(
201  'declare',
202  '	  l_enabled boolean := case when :P10020_END_USER_STYLE = ''Yes'' then true else false end;',
203  'begin',
204  '	  for l_theme in ( select theme_number',
205  '			     from apex_applications',
206  '			    where application_id  = :APP_ID )',
207  '	  loop',
208  '	      if l_enabled then',
209  '		  apex_theme.enable_user_style (',
210  '		      p_application_id => :APP_ID,',
211  '		      p_theme_number   => l_theme.theme_number );',
212  '	      else',
