SQL> -- view: messages_per_day_v — daily message counts (NOTE: ORDER BY in views is ignored at query time)
SQL> create or replace view orac.messages_per_day_v as
  2  select
  3    trunc(m.created_on) as day,
  4    count(*) as messages
  5  from orac.messages m
  6  group by trunc(m.created_on)
  7  order by day;

View created.

Elapsed: 00:00:00.03
SQL> 
SQL> -- view: llm_usage_breakdown_v — message counts by conversation default llm
SQL> create or replace view orac.llm_usage_breakdown_v as
  2  select
  3    l.name as model_name,
  4    count(*) as usage_count
  5  from orac.messages m
  6  join orac.conversations c on m.conversation_id = c.conversation_id
  7  join orac.llm_registry l on c.llm_id = l.llm_id
  8  group by l.name
  9  order by usage_count desc;

View created.

Elapsed: 00:00:00.00
SQL> 
SQL> -- view: token_usage_trend_v — total tokens per day (where tracked)
SQL> create or replace view orac.token_usage_trend_v as
  2  select
  3    trunc(m.created_on) as day,
  4    sum(m.tokens_used) as total_tokens
  5  from orac.messages m
  6  where m.tokens_used is not null
  7  group by trunc(m.created_on)
  8  order by day;

View created.

Elapsed: 00:00:00.00
SQL> 
SQL> -- view: message_role_breakdown_v — counts by role
SQL> create or replace view orac.message_role_breakdown_v as
  2  select
  3    m.role,
  4    count(*) as message_count
  5  from orac.messages m
  6  group by m.role;

View created.

Elapsed: 00:00:00.01
