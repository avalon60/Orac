158  wwv_flow_imp_page.create_page_process(
159   p_id=>wwv_flow_imp.id(11594619610769313)
160  ,p_process_sequence=>10
161  ,p_process_point=>'AFTER_SUBMIT'
162  ,p_process_type=>'NATIVE_PLSQL'
163  ,p_process_name=>'Create Collections'
164  ,p_process_sql_clob=>wwv_flow_string.join(wwv_flow_t_varchar2(
165  'declare',
166  '	  l_line      varchar2(32767);',
167  '	  l_emails    apex_t_varchar2;',
168  '	  l_username  varchar2(4000);',
169  '	  l_at	      number;',
170  '	  l_dot       number;',
171  '	  l_valid     boolean := true;',
172  '	  l_domain    varchar2(4000);',
173  'begin',
174  '	  -- create collections',
175  '	  apex_collection.create_or_truncate_collection(''ACL_BULK_USER_INVALID'');',
176  '	  apex_collection.create_or_truncate_collection(''ACL_BULK_USER_VALID'');',
177  '',
178  '	  -- replace delimiting characters with commas',
179  '	  l_line := :P10043_PRELIM_USERS;',
180  '	  l_line := replace(l_line, chr(10), '' '');',
181  '	  l_line := replace(l_line, chr(13), '' '');',
182  '	  l_line := replace(l_line, chr(9),  '' '');',
183  '	  l_line := replace(l_line, ''<'', '' '');',
184  '	  l_line := replace(l_line, ''>'', '' '');',
185  '	  l_line := replace(l_line, '';'', '' '');',
186  '	  l_line := replace(l_line, '':'', '' '');',
187  '	  l_line := replace(l_line, ''('', '' '');',
188  '	  l_line := replace(l_line, '')'', '' '');',
189  '	  l_line := replace(l_line, '' '', '','');',
190  '',
191  '	  -- get one comma separated line of emails',
192  '	  for j in 1 .. 1000 loop',
193  '	      if instr(l_line, '',,'') > 0 then',
194  '		  l_line := replace(l_line, '',,'', '','');',
195  '	      else',
196  '		  exit;',
197  '	      end if;',
198  '	  end loop;',
199  '',
200  '	  -- get an array of emails',
201  '	  l_emails := apex_string.split(l_line, '','');',
202  '',
203  '	  -- add emails to a collection',
204  '	  l_username := null;',
205  '	  l_domain   := null;',
206  '	  l_at	     := 0;',
207  '	  l_dot      := 0;',
208  '	  for j in 1..l_emails.count loop',
209  '	      l_valid	 := true;',
210  '	      l_username := upper(trim(l_emails(j)));',
211  '	      l_username := trim(both ''.'' from l_username);',
212  '	      l_username := replace(l_username, '' '', null);',
213  '	      l_username := replace(l_username, chr(10), null);',
214  '	      l_username := replace(l_username, chr(9), null);',
215  '	      l_username := replace(l_username, chr(13), null);',
216  '	      l_username := replace(l_username, chr(49824), null);',
217  '',
218  '	      if l_username is not null then',
219  '		  if nvl(:P10043_USERNAME_FORMAT,''x'') = ''EMAIL'' then',
220  '		    -- Validate',
221  '		    l_at     := instr(nvl(l_username, ''x''), ''@'');',
222  '		    l_domain := substr(l_username, l_at+1);',
223  '		    l_dot    := instr(l_domain, ''.'');',
224  '		    if l_at < 2 then',
225  '			-- invalid email',
226  '			apex_collection.add_member(',
227  '			    p_collection_name => ''ACL_BULK_USER_INVALID'',',
228  '			    p_c001	      => l_username,',
229  '			    p_c002	      => apex_lang.message(''APEX.FEATURE.ACL.BULK_USER.MISSING_AT_SIGN''));',
230  '			commit;',
231  '			l_valid := false;',
232  '		    end if;',
233  '',
234  '		    if l_dot = 0 and l_valid then',
235  '			apex_collection.add_member(',
236  '			    p_collection_name => ''ACL_BULK_USER_INVALID'',',
237  '			    p_c001	      => l_username,',
238  '			    p_c002	      => apex_lang.message(''APEX.FEATURE.ACL.BULK_USER.MISSING_DOT''));',
239  '			commit;',
240  '			l_valid := false;',
241  '		    end if;',
242  '		  end if;',
243  '',
244  '		  if l_valid and length(l_username) > 255 then',
245  '		      apex_collection.add_member(',
246  '			  p_collection_name => ''ACL_BULK_USER_INVALID'',',
247  '			  p_c001	    => l_username,',
248  '			  p_c002	    => apex_lang.message(''APEX.FEATURE.ACL.BULK_USER.USERNAME_TOO_LONG''));',
249  '		      commit;',
250  '		      l_valid := false;',
251  '		  end if;',
252  '',
253  '		  if l_valid then',
254  '		      for c1 in (select user_name username',
255  '				   from APEX_APPL_ACL_USERS',
256  '				  where user_name = l_username and application_id = :APP_ID)',
257  '		      loop',
258  '			  apex_collection.add_member(',
259  '			      p_collection_name => ''ACL_BULK_USER_INVALID'',',
260  '			      p_c001		=> l_username,',
261  '			      p_c002		=> apex_lang.message(''APEX.FEATURE.ACL.BULK_USER.ALREADY_IN_ACL''));',
262  '			  commit;',
263  '			  l_valid := false;',
264  '			  exit;',
265  '		      end loop;',
266  '		  end if;',
267  '',
268  '		  if l_valid then',
269  '		      for c1 in (select c001',
270  '				   from apex_collections',
271  '				  where collection_name = ''ACL_BULK_USER_VALID''',
272  '				    and c001		= l_username)',
273  '		      loop',
274  '			  apex_collection.add_member(',
275  '			      p_collection_name => ''ACL_BULK_USER_INVALID'',',
276  '			      p_c001		=> l_username,',
277  '			      p_c002		=> apex_lang.message(''APEX.FEATURE.ACL.BULK_USER.DUPLICATE_USER''));',
278  '			      commit;',
279  '			  l_valid := false;',
280  '			  exit;',
281  '		      end loop;',
282  '		  end if;',
283  '',
284  '		  if l_valid then',
285  '		      apex_collection.add_member(',
286  '			  p_collection_name => ''ACL_BULK_USER_VALID'',',
287  '			  p_c001	    => l_username,',
288  '			  p_c002	    => null,',
289  '			  p_c003	    => :P10043_ROLE);',
290  '			  commit;',
291  '		  end if;',
292  '',
293  '	      end if;',
294  '	      l_username := null;',
295  '	  end loop;',
296  'end;'))
297  ,p_process_clob_language=>'PLSQL'
