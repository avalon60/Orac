SQL> -- view: user_preferences_v — friendly projection with display-ready scalar (no quotes for strings)
SQL> create or replace view orac.user_preferences_v as
  2  select
  3    p.pref_id,		  -- primary key (unique, not null)
  4    p.user_id,
  5    p.pref_key,
  6    p.value_type,		  -- 'string' | 'number' | 'boolean'
  7    p.row_version,		  -- for optimistic locking in APEX (optional but nice)
  8    /* Human-friendly value with quotes removed for strings */
  9    case p.value_type
 10  	 when 'string'	then json_value(p.pref_value, '$' returning varchar2(4000) null on error)
 11  	 when 'number'	then to_char(json_value(p.pref_value, '$' returning number	   null on error))
 12  	 when 'boolean' then lower(json_value(p.pref_value, '$' returning varchar2(5)	  null on error))
 13    end as value_display
 14  from orac.user_preferences p;

View created.

