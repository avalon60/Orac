 37  'select feedback_id id,',
 38  '	  page_id||''. ''||page_name page_name,',
 39  '	  created_on created,',
 40  '	  lower(created_by) created_by,',
 41  '	  feedback,',
 42  '	  feedback_rating rating,',
 43  '	  case feedback_rating',
 44  '	    when 1 then ''fa-frown-o feedback-negative'' ',
 45  '	    when 2 then ''fa-emoji-neutral feedback-neutral''  ',
 46  '	    when 3 then ''fa-smile-o feedback-positive''',
 47  '	  end rating_icon,',
 48  '	  feedback_status status,',
 49  '	  public_response response,',
 50  '	  http_user_agent user_agent,',
 51  '	  updated_on updated,',
 52  '	  lower(updated_by) updated_by,',
 53  '	  page_id',
 54  'from apex_team_feedback f',
 55  'where application_id = :APP_ID'))
