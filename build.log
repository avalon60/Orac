SQL> SQL> create or replace package body orac_utils
  2  as
  3    function header(p_name in varchar2) return varchar2
  4    is
  5    begin
  6  	 return owa_util.get_cgi_env('HTTP_' || replace(upper(p_name), '-', '_'));
  7    end;
  8  
  9    function b64url_to_raw(p_b64url in varchar2) return raw
 10    is
 11  	 l_b64 varchar2(32767) := replace(replace(p_b64url, '-', '+'), '_', '/');
 12  	 l_pad pls_integer := mod(4 - mod(length(l_b64), 4), 4);
 13    begin
 14  	 if l_pad > 0 then
 15  	   l_b64 := l_b64 || rpad('=', l_pad, '=');
 16  	 end if;
 17  	 return utl_encode.base64_decode(utl_raw.cast_to_raw(l_b64));
 18    end;
 19  
 20    function hmac_sha256(p_secret_raw in raw, p_message in varchar2) return raw
 21    is
 22    begin
 23  	 return dbms_crypto.mac(
 24  	   src => utl_raw.cast_to_raw(p_message),
 25  	   typ => dbms_crypto.hmac_sh256,
 26  	   key => p_secret_raw
 27  	 );
 28    end;
