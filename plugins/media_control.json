{
  "schema_version": 2,
  "plugin_id": "media_control",
  "name": "Media Control",
  "description": "Handles playback control for TVs, speakers, and media scenes across the home.",
  "version": "1.0.0",
  "python_dependencies": [],
  "enabled": true,
  "capabilities": [
    "media.playback_control",
    "media.volume_control",
    "media.source_selection"
  ],
  "entitlements": [],
  "entities": [
    "tv",
    "speaker",
    "playlist",
    "volume",
    "input_source"
  ],
  "examples": [
    "Pause the lounge TV.",
    "Turn the volume down in the kitchen.",
    "Play jazz in the study."
  ],
  "entry_point": "plugin:MediaControlPlugin",
  "routing": {
    "capabilities": [
      {
        "id": "media.playback_control",
        "description": "Control media playback on TVs, speakers, and media devices.",
        "intents": [
          {
            "name": "playback_control",
            "examples": [
              "Pause the lounge TV.",
              "Play jazz in the study.",
              "Stop the kitchen speaker."
            ],
            "requires_confirmation": true,
            "safety_level": "device_control"
          }
        ]
      },
      {
        "id": "media.volume_control",
        "description": "Adjust media volume.",
        "intents": [
          {
            "name": "volume_control",
            "examples": [
              "Turn the volume down in the kitchen.",
              "Raise the TV volume."
            ],
            "requires_confirmation": true,
            "safety_level": "device_control"
          }
        ]
      }
    ]
  },
  "execution": {
    "action_type": "device_control",
    "requires_confirmation": true,
    "allowed_by_default": false,
    "capabilities": [
      "media.playback_control",
      "media.volume_control",
      "media.source_selection"
    ],
    "entitlements": [],
    "scaffold": true,
    "notes": "Media control remains a non-executable scaffold until a managed provider is implemented."
  },
  "runtime": {
    "mode": "on_demand"
  },
  "configuration": {
    "required": [],
    "optional": []
  },
  "database": {
    "required": false,
    "on_missing": "warn_disable",
    "schemas": []
  }
}
