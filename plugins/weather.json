{
  "schema_version": 2,
  "plugin_id": "weather",
  "name": "Weather",
  "description": "Answers current weather and short forecast questions for the user's configured or supported locations.",
  "version": "1.0.0",
  "enabled": true,
  "capabilities": [
    "weather.current_conditions",
    "weather.short_forecast"
  ],
  "entitlements": [
    "user_preferences.weather_location",
    "user_preferences.timezone"
  ],
  "entities": [
    "location",
    "temperature",
    "forecast",
    "rain",
    "wind",
    "time_period"
  ],
  "examples": [
    "Will it rain today?",
    "What's the weather where I am?",
    "What's the weather in Manchester?",
    "Do I need a coat this evening?",
    "Will it be windy tomorrow morning?",
    "What's the temperature outside?"
  ],
  "entry_point": "plugin:WeatherPlugin",
  "runtime": {
    "mode": "on_demand"
  },
  "configuration": {
    "required": [],
    "optional": [
      {
        "section": "weather",
        "key": "default_location",
        "type": "string",
        "description": "Fallback weather location used when no user preference or explicit location is available."
      }
    ]
  },
  "database": {
    "required": false,
    "on_missing": "warn_disable",
    "schemas": []
  }
}
