{
  "schema_version": 2,
  "plugin_id": "weather",
  "name": "Weather",
  "description": "Answers current weather and short forecast questions for the user's configured or supported locations.",
  "version": "1.0.2",
  "python_dependencies": [
    "requests>=2.32,<3"
  ],
  "enabled": true,
  "capabilities": [
    "weather.current_conditions",
    "weather.short_forecast"
  ],
  "entitlements": [
    "user_preferences.user_location",
    "user_preferences.timezone"
  ],
  "entities": [
    "location",
    "temperature",
    "forecast",
    "rain",
    "wind",
    "time_period"
  ],
  "examples": [
    "Will it rain today?",
    "What's the weather where I am?",
    "What's the weather in Manchester?",
    "Do I need a coat this evening?",
    "Will it be windy tomorrow morning?",
    "What's the temperature outside?"
  ],
  "entry_point": "plugin:WeatherPlugin",
  "routing": {
    "capabilities": [
      {
        "id": "weather.current_conditions",
        "description": "Answer current weather and outside-condition questions.",
        "intents": [
          {
            "name": "current_weather",
            "examples": [
              "What's the weather where I am?",
              "What's the weather in Manchester?",
              "What's the temperature outside?"
            ],
            "requires_confirmation": false,
            "safety_level": "informational_read_only"
          }
        ]
      },
      {
        "id": "weather.short_forecast",
        "description": "Answer short weather forecast questions.",
        "intents": [
          {
            "name": "short_forecast",
            "examples": [
              "Will it rain today?",
              "Do I need a coat this evening?",
              "Will it be windy tomorrow morning?"
            ],
            "requires_confirmation": false,
            "safety_level": "external_read"
          }
        ]
      }
    ]
  },
  "execution": {
    "action_type": "informational_read_only",
    "requires_confirmation": false,
    "allowed_by_default": true,
    "capabilities": [
      "weather.current_conditions",
      "weather.short_forecast"
    ],
    "entitlements": [
      "user_preferences.user_location",
      "user_preferences.timezone"
    ]
  },
  "runtime": {
    "mode": "on_demand"
  },
  "configuration": {
    "required": [],
    "optional": [
      {
        "section": "weather",
        "key": "default_location",
        "type": "string",
        "description": "Fallback user location used when no user preference or explicit location is available."
      }
    ]
  },
  "database": {
    "required": false,
    "on_missing": "warn_disable",
    "schemas": []
  }
}
