[home_assistant]
protocol = http
host = %home_assistant_host%
port = 8123
verify_ssl = false
websocket_path = /api/websocket
sync_on_startup = true
structural_refresh_mode = hourly
structural_refresh_minutes = 60
enable_websocket = true
ws_reconnect_seconds = 10
enable_state_poll_fallback = false
state_poll_seconds = 120
log_level = INFO
