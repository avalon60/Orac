<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.30.xsd">

  <includeAll path="table" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="index" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="constraint_pk" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="constraint_uc" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="constraint_other" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="constraint_fk" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="trigger" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="seed_data" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
  <includeAll path="comment" relativeToChangelogFile="true" errorIfMissingOrEmpty="false"/>
</databaseChangeLog>
