# Orac environment configuration.
#
# This file is valid both as a Bash-sourced configuration file and as a
# Docker Compose --env-file input.

# -----------------------------------------------------------------------------
# Oracle Database Container Settings
# -----------------------------------------------------------------------------

# Compose project name.
COMPOSE_PROJECT_NAME=orac

# Name of the Docker container for Oracle DB + ORDS.
ORAC_DB_CONTAINER_NAME=orac-db

# Backwards-compatible alias used by older scripts.
CONTAINER_NAME=orac-db

# Host directory to persist Oracle data files
ORADATA_DIR=/u01/orac-db/oradata

# Local image built from Dockerfile under ORA_DOCKER_DIR
ORAC_IMAGE_NAME=orac
ORAC_IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Port Mappings
# -----------------------------------------------------------------------------

# SQL*Net listener port on host (maps to 1521 inside container)
PORT_SQLNET=1521

# ORDS/HTTP port on host (maps to 8080 inside container)
PORT_HTTP=8042

# Enterprise Manager port on host (maps to 5500 inside container)
PORT_EM=5500

# -----------------------------------------------------------------------------
# Optional Kokoro voice sidecar
# -----------------------------------------------------------------------------

KOKORO_IMAGE=ghcr.io/remsky/kokoro-fastapi-cpu:latest
KOKORO_CONTAINER_NAME=orac-kokoro
KOKORO_HOST=127.0.0.1
KOKORO_PORT=8880
KOKORO_DOCKER_RUNTIME=

# -----------------------------------------------------------------------------
# Optional SearXNG retrieval sidecar
# -----------------------------------------------------------------------------

SEARXNG_IMAGE=searxng/searxng:latest
SEARXNG_CONTAINER_NAME=orac-searxng
SEARXNG_HOST=127.0.0.1
SEARXNG_PORT=8888

# Deployment topology (currently only db-local supported.
TOPOLOGY=db-local
ORACDB_TNS_ALIAS=orac-pdb
# ORACDB_TNS_ALIAS=orac_high
ORACDB_WALLET_DIR=~/.orac/wallets/orac_adb
