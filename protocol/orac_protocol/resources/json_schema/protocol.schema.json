{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orac/protocol.schema.json",
  "title": "orac message envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "type", "id", "ts", "route"],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "type": { "type": "string", "enum": [
      "request",
      "response",
      "event",
      "stream_start",
      "text_delta",
      "text_chunk",
      "stream_end",
      "stream_error",
      "stream_cancelled",
      "retrieval_start",
      "retrieval_query",
      "retrieval_fetch_start",
      "retrieval_fetch_complete",
      "retrieval_complete",
      "retrieval_failed",
      "retrieval_skipped",
      "tts_playback_started",
      "tts_playback_finished",
      "tts_playback_cancelled",
      "tts_playback_error",
      "voice_turn_complete"
    ] },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reply_to": { "type": "string" },
    "ts": { "type": "string", "format": "date-time" },
    "route": { "type": "string", "minLength": 1, "maxLength": 128 },
    "meta": { "type": "object", "default": {}, "additionalProperties": true },
    "payload": { "oneOf": [
      { "type": "null" },
      { "$ref": "#/$defs/promptRequestPayload" },
      { "$ref": "#/$defs/promptResponsePayload" },
      { "$ref": "#/$defs/streamStartPayload" },
      { "$ref": "#/$defs/streamDeltaPayload" },
      { "$ref": "#/$defs/textChunkPayload" },
      { "$ref": "#/$defs/streamEndPayload" },
      { "$ref": "#/$defs/streamTerminalPayload" },
      { "$ref": "#/$defs/retrievalEventPayload" },
      { "$ref": "#/$defs/ttsPlaybackEventPayload" },
      { "$ref": "#/$defs/voiceCancelRequestPayload" },
      { "$ref": "#/$defs/voiceCancelResponsePayload" },
      { "$ref": "#/$defs/helloPayload" }
    ]},
    "error": { "oneOf": [
      { "type": "null" },
      { "$ref": "#/$defs/errorObj" }
    ]}
  },

  "allOf": [
    {
      "if": { "properties": { "type": { "const": "request" }, "route": { "const": "orac.prompt" } }, "required": ["type", "route"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/promptRequestPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "request" }, "route": { "const": "orac.voice.cancel" } }, "required": ["type", "route"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/voiceCancelRequestPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "response" }, "route": { "const": "orac.voice.cancel" } }, "required": ["type", "route"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/voiceCancelResponsePayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "response" }, "route": { "const": "orac.prompt" } }, "required": ["type", "route"] },
      "then": { "properties": { "payload": { "oneOf": [
        { "$ref": "#/$defs/promptResponsePayload" }, { "type": "null" }
      ] } } }
    },
    {
      "if": { "properties": { "type": { "const": "stream_start" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/streamStartPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "text_delta" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/streamDeltaPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "text_chunk" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/textChunkPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "stream_end" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/streamEndPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "stream_error" } }, "required": ["type"] },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/streamTerminalPayload" },
          "error": { "$ref": "#/$defs/errorObj" }
        },
        "required": ["payload", "error"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "stream_cancelled" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/streamTerminalPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_start" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_query" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_fetch_start" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_fetch_complete" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_complete" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_failed" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "retrieval_skipped" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/retrievalEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "enum": [
        "tts_playback_started",
        "tts_playback_finished",
        "tts_playback_cancelled",
        "voice_turn_complete"
      ] } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/ttsPlaybackEventPayload" } }, "required": ["payload"] }
    },
    {
      "if": { "properties": { "type": { "const": "tts_playback_error" } }, "required": ["type"] },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/ttsPlaybackEventPayload" },
          "error": { "$ref": "#/$defs/errorObj" }
        },
        "required": ["payload", "error"]
      }
    },
    {
      "if": { "properties": { "type": { "const": "event" }, "route": { "const": "orac.prompt" } }, "required": ["type", "route"] },
      "then": {
        "properties": {
          "meta": {
            "type": "object",
            "properties": { "event": { "type": "string", "enum": ["start", "delta", "end", "error"] } },
            "required": ["event"],
            "additionalProperties": true
          }
        },
        "anyOf": [
          { "properties": { "meta": { "properties": { "event": { "const": "start" } } }, "payload": { "$ref": "#/$defs/streamStartPayload" } } },
          { "properties": { "meta": { "properties": { "event": { "const": "delta" } } }, "payload": { "$ref": "#/$defs/streamDeltaPayload" } } },
          { "properties": { "meta": { "properties": { "event": { "const": "end" } } }, "payload": { "$ref": "#/$defs/streamEndPayload" } } },
          { "properties": { "meta": { "properties": { "event": { "const": "error" } } }, "error": { "$ref": "#/$defs/errorObj" } } }
        ]
      }
    }
  ],

  "$defs": {
    "chatMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "content"],
      "properties": {
        "role": { "type": "string", "enum": ["system", "user", "assistant"] },
        "content": { "type": "string" }
      }
    },

    "promptRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["messages"],
      "properties": {
        "messages": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/chatMessage" } },
        "tools": { "type": "array", "items": { "type": "object" } },
        "model_pref": { "type": "object", "additionalProperties": true },
        "context": { "type": "object", "additionalProperties": true },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "mime", "size"],
            "properties": {
              "name": { "type": "string" },
              "mime": { "type": "string" },
              "size": { "type": "integer", "minimum": 0 },
              "sha256": { "type": "string" },
              "transport": { "type": "object", "additionalProperties": true }
            }
          }
        }
      }
    },

    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      }
    },

    "promptResponsePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "stop_reason", "usage"],
      "properties": {
        "content": { "type": "string" },
        "stop_reason": { "type": "string", "enum": ["stop", "length", "tool_call", "error"] },
        "usage": { "$ref": "#/$defs/usage" }
      }
    },

    "streamStartPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "content_type": { "type": "string", "enum": ["text"] },
        "voice_session_id": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] },
        "model": {
          "type": "string",
          "description": "Legacy compatibility field; current runtime emits model identity in envelope meta.model."
        }
      },
      "anyOf": [
        { "required": ["content_type"] },
        { "required": ["model"] }
      ]
    },

    "streamDeltaPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "delta": { "type": "string" },
        "content_delta": {
          "type": "string",
          "description": "Legacy alias for delta; current runtime emits delta."
        },
        "voice_session_id": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] }
      },
      "anyOf": [
        { "required": ["delta"] },
        { "required": ["content_delta"] }
      ]
    },

    "textChunkPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chunk"],
      "properties": {
        "chunk": { "type": "string" },
        "session_id": { "type": ["string", "null"] },
        "voice_session_id": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] }
      }
    },

    "streamEndPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stop_reason"],
      "properties": {
        "stop_reason": { "type": "string", "enum": ["stop", "length", "tool_call", "error"] },
        "voice_session_id": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] },
        "usage": { "$ref": "#/$defs/usage" }
      }
    },

    "streamTerminalPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": { "type": "string" },
        "voice_session_id": { "type": ["string", "null"] },
        "turn_id": { "type": ["string", "null"] }
      },
      "anyOf": [
        { "required": ["reason"] },
        { "required": ["voice_session_id"] },
        { "required": ["turn_id"] }
      ]
    },

    "retrievalEventPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string" },
        "reason": { "type": "string" },
        "query": { "type": "string" },
        "provider": { "type": "string" },
        "source_count": { "type": "integer", "minimum": 0 },
        "fetched_count": { "type": "integer", "minimum": 0 },
        "usable_source_count": { "type": "integer", "minimum": 0 }
      }
    },

    "ttsPlaybackEventPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_id", "timestamp"],
      "properties": {
        "turn_id": { "type": "string", "minLength": 1 },
        "request_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "chunk_id": { "type": "string" },
        "utterance_id": { "type": "string" },
        "reason": { "type": "string" }
      }
    },

    "voiceCancelRequestPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "reason"],
      "properties": {
        "session_id": { "type": "string", "minLength": 1 },
        "turn_id": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "enum": ["turn", "session", "active", "all"] },
        "reason": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "scope": { "const": "turn" } }, "required": ["scope"] },
          "then": { "required": ["session_id", "turn_id"] }
        },
        {
          "if": { "properties": { "scope": { "enum": ["session", "active"] } }, "required": ["scope"] },
          "then": { "required": ["session_id"] }
        }
      ]
    },

    "voiceCancelResponsePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cancelled", "discarded"],
      "properties": {
        "cancelled": { "type": "boolean" },
        "discarded": { "type": "integer", "minimum": 0 }
      }
    },

    "helloPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "want": { "type": "array", "items": { "type": "string" } }
      }
    },

    "errorObj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "http": { "type": "integer", "minimum": 100, "maximum": 599 },
        "details": { "type": "object" }
      }
    }
  }
}
